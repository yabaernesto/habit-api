generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Habit {
  id            String          @id @default(uuid())
  title         String
  created_at    DateTime
  dayHabits     DayHabit[]
  habitWeekDays HabitWeekDays[]

  @@map("habits")
}

model HabitWeekDays {
  id       String @id @default(uuid())
  week_day Int

  habit    Habit  @relation(fields: [habit_id], references: [id])
  habit_id String

  @@unique([habit_id, week_day])
  @@map("habit_week_days")
}

model Day {
  id        String     @id @default(uuid())
  date      DateTime
  dayHabits DayHabit[]

  @@unique([date])
  @@map("days")
}

// Um relacionamento N:N sempre gera uma tabela Pivot. A tabela Pivot é a que guarda aquele relacionamento
model DayHabit {
  id String @id @default(uuid())

  day      Day    @relation(fields: [day_id], references: [id])
  day_id   String
  habit    Habit  @relation(fields: [habit_id], references: [id])
  habit_id String

  @@unique([day_id, habit_id])
  @@map("day_habits")
}
